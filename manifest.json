{
  "manifest_version": 3,
  "name": "CivicEstate",
  "version": "0.1.0",
  "description": "Personalized lifestyle and accessibility intelligence for Zillow listings",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.zillow.com/*",
    "https://maps.googleapis.com/*",
    "https://places.googleapis.com/*",
    "https://api.melissa.com/*",
    "https://api.fbi.gov/*",
    "https://api.usa.gov/*",
    "https://hazards.fema.gov/*",
    "https://egis.fire.ca.gov/*",
    "https://overpass-api.de/*",
    "https://educationdata.urban.org/*",
    "https://generativelanguage.googleapis.com/*",
    "https://offender.io/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.zillow.com/*"],
      "js": ["src/content/index.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/housing_icon_16x16.png",
      "32": "icons/housing_icon_32x32.png",
      "48": "icons/housing_icon_48x48.png",
      "128": "icons/housing_icon_128x128.png"
    }
  },
  "icons": {
    "16": "icons/housing_icon_16x16.png",
    "32": "icons/housing_icon_32x32.png",
    "48": "icons/housing_icon_48x48.png",
    "128": "icons/housing_icon_128x128.png"
  }
}
